# 1. Use the optimized nix-direnv loader
# This caches the devShell environment so it loads instantly.
use flake .

# TODO: add these keys to secrets/env.json for the new fetchers to work:
#   GOG_REFRESH_TOKEN, NEXUS_API_KEY, CURSEFORGE_API_KEY, MODIO_API_KEY, EPIC_LEGENDARY_AUTH

# 2. Define secret paths
SECRET_JSON="secrets/env.json"
TARGET_ENV=".env"

# 3. Decrypt and load secrets
if [ -f "$SECRET_JSON" ]; then
    echo "🔐 Decrypting secrets via sops..."
    
    # Decrypt JSON to standard ENV variables and save to .env
    sops -d "$SECRET_JSON" | jq -r 'to_entries | .[] | "export \(.key)=\"\(.value)\""' > "$TARGET_ENV"
    
    # Load the local .env into the current environment
    dotenv "$TARGET_ENV"
    
    if [ -f .env ]; then
        export NIX_CONFIG="extra-sandbox-paths = /secrets=/tmp/.env?"
        cp .env /tmp/.env
        chmod go-rw /tmp/.env
        setfacl -m g:nixbld:rwx /tmp/.env
    fi
    # Tell nix-direnv to trigger a reload if the secrets file changes
    watch_file "$SECRET_JSON"
else
    echo "⚠️ Warning: $SECRET_JSON not found."
fi
